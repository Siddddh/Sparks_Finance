rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public scan data (read-only; Python Admin SDK writes) ──
    match /scans/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /history/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /agent_results/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /earnings/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /catalysts/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /opportunities/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Agent analysis queue (browser queues tickers, Python processes them) ──
    match /agent_queue/{ticker} {
      allow read, write: if request.auth != null;
    }

    // ── User profile ──
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Portfolios — parent doc + subcollection ──
    match /portfolios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /portfolios/{uid}/list/{portfolioId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Holdings ──
    match /holdings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /holdings/{uid}/{portfolioId}/{holdingId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Watchlists ──
    match /watchlists/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /watchlists/{uid}/list/{watchlistId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Personal alerts ──
    match /alerts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /alerts/{uid}/list/{alertId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── AI reports (Python writes via Admin SDK; browser reads) ──
    match /ai_reports/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /ai_reports/{uid}/reports/{date} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Portfolio health reports (Python writes; browser reads) ──
    match /health_reports/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /health_reports/{uid}/reports/{date} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Pre-market notifications (Cloud Function writes via Admin SDK; browser reads) ──
    match /notifications/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /notifications/{uid}/list/{notificationId} {
      // Browser may read its own digests and mark them read; only the
      // Cloud Function (Admin SDK) creates or deletes them.
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow create, delete: if false;
    }
  }
}
